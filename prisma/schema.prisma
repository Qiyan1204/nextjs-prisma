// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  password            String?              // 可选，因为 Google 登录不需要密码
  role                Role                 @default(INVESTOR)
  status              UserStatus           @default(ACTIVE)
  walletBalance       Decimal              @default(0) @db.Decimal(18, 6)
  image               String?              // Google 头像
  emailVerified       DateTime?            // NextAuth 需要
  posts               Post[]
  passwordResetTokens PasswordResetToken[]
  accounts            Account[]            // NextAuth OAuth 账户
  sessions            Session[]            // NextAuth 会话
  createdAt           DateTime             @default(now())

  // PolyOiyen relations
  polyTransactions    PolyTransaction[]
  createdMarkets      Market[]             @relation("MarketCreator")
  orders              Order[]
  positions           Position[]
  resolutions         Resolution[]         @relation("MarketResolver")
  polyBets            PolyBet[]
  polyAlerts          PolyAlert[]
}

// NextAuth Account 模型（用于 OAuth）
model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth Session 模型
model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// NextAuth VerificationToken 模型（用于邮箱验证）
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  authorId  Int
  author    User    @relation(fields: [authorId], references: [id])
}

// Stock price history for moving average calculations
model StockPrice {
  id        Int      @id @default(autoincrement())
  symbol    String
  date      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    BigInt?
  createdAt DateTime @default(now())

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
}

// Watchlist items
model WatchlistItem {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  name      String
  emoji     String   @default("📈")
  createdAt DateTime @default(now())
}

// Portfolio positions
model Portfolio {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  shares    Float
  avgPrice  Float
  totalCost Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Transaction history
model Transaction {
  id        Int      @id @default(autoincrement())
  symbol    String
  type      String   // 'buy' or 'sell'
  shares    Float
  price     Float
  total     Float
  createdAt DateTime @default(now())

  @@index([symbol])
}

// Backtest results storage
model BacktestResult {
  id              Int      @id @default(autoincrement())
  symbol          String
  strategyName    String
  startDate       DateTime
  endDate         DateTime
  initialCapital  Float
  finalValue      Float
  totalReturn     Float
  totalTrades     Int
  winningTrades   Int
  losingTrades    Int
  maxDrawdown     Float
  sharpeRatio     Float?
  tradesJson      String   // JSON string of all trades
  createdAt       DateTime @default(now())

  @@index([symbol])
}

enum Role {
  STUDENT
  ADMIN
  INVESTOR
  USER
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum MarketStatus {
  OPEN
  CLOSED
  RESOLVED
}

enum MarketResolution {
  YES
  NO
}

enum OrderType {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  FILLED
  CANCELLED
}

enum PolyTransactionType {
  DEPOSIT
  WITHDRAW
  TRADE
}

// ─────────────────────────────────────────────
// PolyOiyen Models
// ─────────────────────────────────────────────

// Wallet transaction history (balance stored on User.walletBalance)
model PolyTransaction {
  id           Int                  @id @default(autoincrement())
  userId       Int
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         PolyTransactionType
  amount       Decimal              @db.Decimal(18, 6)
  balanceAfter Decimal              @db.Decimal(18, 6)
  createdAt    DateTime             @default(now())

  @@index([userId])
}

// Prediction market
model Market {
  id          Int              @id @default(autoincrement())
  title       String
  description String?
  category    String?
  creatorId   Int
  creator     User             @relation("MarketCreator", fields: [creatorId], references: [id])
  endDate     DateTime
  status      MarketStatus     @default(OPEN)
  resolution  MarketResolution?
  createdAt   DateTime         @default(now())
  outcomes    Outcome[]
  orders      Order[]
  positions   Position[]
  resolutionRecord Resolution?

  @@index([creatorId])
  @@index([status])
}

// Possible outcomes of a market (e.g. YES / NO)
model Outcome {
  id          Int       @id @default(autoincrement())
  marketId    Int
  market      Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  name        String    // e.g. "YES", "NO", "Candidate A"
  price       Decimal   @db.Decimal(10, 6)  // probability price 0–1
  totalShares Decimal   @default(0) @db.Decimal(18, 6)
  orders      Order[]
  positions   Position[]
  resolutions Resolution[] @relation("WinningOutcome")

  @@index([marketId])
}

// Trading order placed by a user
model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  user       User        @relation(fields: [userId], references: [id])
  marketId   Int
  market     Market      @relation(fields: [marketId], references: [id])
  outcomeId  Int
  outcome    Outcome     @relation(fields: [outcomeId], references: [id])
  orderType  OrderType
  price      Decimal     @db.Decimal(10, 6)
  shares     Decimal     @db.Decimal(18, 6)
  status     OrderStatus @default(OPEN)
  createdAt  DateTime    @default(now())
  buyTrades  Trade[]     @relation("BuyOrder")
  sellTrades Trade[]     @relation("SellOrder")

  @@index([userId])
  @@index([marketId])
  @@index([outcomeId])
  @@index([status])
}

// Executed trade matching a buy and sell order
model Trade {
  id          Int      @id @default(autoincrement())
  buyOrderId  Int
  buyOrder    Order    @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellOrderId Int
  sellOrder   Order    @relation("SellOrder", fields: [sellOrderId], references: [id])
  price       Decimal  @db.Decimal(10, 6)
  shares      Decimal  @db.Decimal(18, 6)
  executedAt  DateTime @default(now())

  @@index([buyOrderId])
  @@index([sellOrderId])
}

// User's current holdings per outcome
model Position {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  marketId    Int
  market      Market   @relation(fields: [marketId], references: [id])
  outcomeId   Int
  outcome     Outcome  @relation(fields: [outcomeId], references: [id])
  sharesOwned Decimal  @default(0) @db.Decimal(18, 6)

  @@unique([userId, marketId, outcomeId])   // one position per (user, market, outcome)
  @@index([userId])
  @@index([marketId])
}

// Market resolution record
model Resolution {
  id               Int      @id @default(autoincrement())
  marketId         Int      @unique
  market           Market   @relation(fields: [marketId], references: [id])
  winningOutcomeId Int
  winningOutcome   Outcome  @relation("WinningOutcome", fields: [winningOutcomeId], references: [id])
  resolvedAt       DateTime @default(now())
  resolvedBy       Int      // FK → User
  resolver         User     @relation("MarketResolver", fields: [resolvedBy], references: [id])

  @@index([winningOutcomeId])
  @@index([resolvedBy])
}

// PolyOiyen: user bets on Polymarket events (persisted)
model PolyBet {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId         String   // Polymarket event id (slug or condition_id)
  marketQuestion  String   // snapshot of the question
  side            String   // "YES" or "NO"
  type            String   @default("BUY") // "BUY", "SELL", or "CLAIM"
  amount          Decimal  @db.Decimal(18, 6)
  shares          Decimal  @db.Decimal(18, 6)
  price           Decimal  @db.Decimal(10, 6)  // avg price per share
  category        String   @default("Other") // event category tag for pie chart
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([eventId])
}

// PolyOiyen: user price & large-order alerts
model PolyAlert {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId        String   // Polymarket event id
  tokenId        String   // CLOB token id for the outcome being watched
  marketQuestion String
  alertType      String   // "PRICE" or "LARGE_ORDER"
  side           String   // "YES" or "NO"
  severity       String   @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH" | "CRITICAL"
  cooldownMinutes Int     @default(30)
  targetPrice    Decimal? @db.Decimal(10, 6)  // for PRICE alerts: trigger when price crosses this
  threshold      Decimal? @db.Decimal(18, 6)  // for LARGE_ORDER: min $ size to trigger
  triggered      Boolean  @default(false)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  triggeredAt    DateTime?
  lastNotifiedAt DateTime?

  @@index([userId])
  @@index([eventId])
}

// Persistent API pull/execution telemetry for OiyenCompare density charts
model PullMetric {
  id        Int      @id @default(autoincrement())
  kind      String   // "poly_probe" | "invest_pull" | "invest_action"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([kind, createdAt])
}

// Persistent order book depth snapshots for Polyoiyen markets
model MarketDepthSnapshot {
  id            Int      @id @default(autoincrement())
  eventId       String
  marketTitle   String
  categoryKey   String
  yesTokenId    String
  noTokenId     String
  yesDepthUsd   Float
  noDepthUsd    Float
  totalDepthUsd Float
  sampledAt     DateTime @default(now())

  @@index([sampledAt])
  @@index([eventId, sampledAt])
  @@index([categoryKey, sampledAt])
}

// Endpoint-level health probe records for Data Health panel analytics
model EndpointProbe {
  id         Int      @id @default(autoincrement())
  endpoint   String
  ok         Boolean
  statusCode Int?
  latencyMs  Int
  createdAt  DateTime @default(now())

  @@index([endpoint, createdAt])
  @@index([createdAt])
}

// Alert notification audit trail: sent vs cooldown-skipped
model AlertNotificationEvent {
  id        Int      @id @default(autoincrement())
  alertId   Int
  eventType String   // "SENT" | "SKIPPED_COOLDOWN"
  channel   String   @default("DISCORD")
  createdAt DateTime @default(now())

  @@index([alertId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// PolyOiyen Backtest Versioning System
// ─────────────────────────────────────────────

// Master backtest model: stores versioned backtest configurations
model ModelBacktest {
  id                Int                   @id @default(autoincrement())
  name              String                // e.g., "PolyOiyen v1.0 - Category-based"
  version           String                // e.g., "1.0", "1.1-beta"
  description       String?
  notes             String?               // Detailed notes on changes, limitations, improvements
  modelType         String                @default("PolyOiyen") // Model name/type
  parameters        String                // JSON: model parameters, thresholds, weights, etc.
  dataStartDate     DateTime?             // When historical data starts
  dataEndDate       DateTime?             // When historical data ends
  status            String                @default("active") // "active" | "archived" | "compare" | "experimental"
  isInversePair     Boolean               @default(false) // true if this is inverse of another model
  parentModelId     Int?                  // FK to parent when isInversePair=true
  parentModel       ModelBacktest?        @relation("InversePair", fields: [parentModelId], references: [id])
  inverseModels     ModelBacktest[]       @relation("InversePair")
  runs              BacktestVersionRun[]
  strategies        StrategyVariant[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([status])
  @@index([modelType, createdAt])
  @@index([parentModelId])
}

// Individual backtest run result with equity curve and metrics
model BacktestVersionRun {
  id                      Int      @id @default(autoincrement())
  modelBacktestId         Int
  modelBacktest           ModelBacktest @relation(fields: [modelBacktestId], references: [id], onDelete: Cascade)
  totalRuns               Int
  aggregateWinRate        Float?
  avgReturn               Float?
  avgMaxDrawdown          Float?
  equityCurveJson         String   // JSON: { aggregate: [...], byStrategy: [...] }
  lossAttributionJson     String   // JSON: loss attribution by strategy
  worstEventsJson         String   // JSON: array of worst events
  diagnosticsJson         String   // JSON: diagnostic data (resolved, unresolved, excluded)
  backtestStatus          String   // "healthy" | "degraded" | "unhealthy" | "sufficient"
  createdAt               DateTime @default(now())

  @@index([modelBacktestId, createdAt])
}

// Strategy variant: tracks original and inverse strategies
model StrategyVariant {
  id                  Int      @id @default(autoincrement())
  modelBacktestId     Int
  modelBacktest       ModelBacktest @relation(fields: [modelBacktestId], references: [id], onDelete: Cascade)
  strategyName        String   // e.g., "Category Momentum"
  isInverse           Boolean  @default(false)
  parentStrategyId    Int?     // FK to original strategy if isInverse=true
  parentStrategy      StrategyVariant? @relation("StrategyInverse", fields: [parentStrategyId], references: [id])
  inverseStrategies   StrategyVariant[] @relation("StrategyInverse")
  runsCount           Int      @default(0)
  winRate             Float?
  avgReturn           Float?
  maxDrawdown         Float?
  lossContributionPct Float?
  createdAt           DateTime @default(now())

  @@index([modelBacktestId])
  @@index([parentStrategyId])
}

// Historical trade snapshots for inverse strategy generation
model BacktestTradeSnapshot {
  id              Int      @id @default(autoincrement())
  modelBacktestId Int
  eventId         String
  strategyName    String
  side            String   // "YES" or "NO"
  amount          Float
  shares          Float
  price           Float
  category        String
  createdAt       DateTime @default(now())

  @@index([modelBacktestId, eventId])
  @@index([strategyName])
}